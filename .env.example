# PostgreSQL Database (Supabase recommended for Vercel)
# Get this from Supabase Dashboard → Settings → Database → Connection String
DATABASE_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Vonalia API (from your bot code)
VONALIA_API_KEY="your-vonalia-api-key-here"

# Discord Webhook for payment notifications
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/..."

# Admin API Key for approve/decline endpoints
ADMIN_API_KEY="your-admin-secret-key-change-this"
