# PostgreSQL Database (Supabase recommended for Vercel)
# IMPORTANT: Use the Transaction Pooler URL (not direct connection) for serverless/Vercel
# Supabase Dashboard → Settings → Database → Transaction Pooler
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-us-east-1.pooler.supabase.com:6543/postgres"

NEXTAUTH_SECRET="your-secret-key-here-change-this-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Vonalia API (from your bot code)
VONALIA_API_KEY="your-vonalia-api-key-here"

# Discord Webhook for payment notifications (REQUIRED)
DISCORD_WEBHOOK_URL="https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN"

# Admin API Key for approve/decline endpoints (REQUIRED - Generate a strong random key)
# Use this in Discord webhook buttons or admin panel requests
# Example: openssl rand -hex 32
ADMIN_API_KEY="your-admin-secret-key-change-this-to-random-string"

# Bio protected links
# NZNT_ACCESS_HASH is SHA-256 of the normalized answer. You can provide multiple hashes separated by commas.
NZNT_ACCESS_HASH="sha256_of_normalized_answer"
NZNT_WHATSAPP_URL="https://wa.me/your_number"
NZNT_INSTAGRAM_URL="https://www.instagram.com/your_username/"
